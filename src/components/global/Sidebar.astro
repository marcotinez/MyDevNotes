---
import { sidebarDomains } from "../../config/sidebar";

const toTitle = (slug: string) =>
  slug
    .split("-")
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

type PageModule = { frontmatter?: { navOrder?: number; navLabel?: string } };

type SidebarTopic = { label: string; href: string; navOrder: number };
type SidebarSection = {
  title: string;
  topics: string[];
  icon: string;
  topicHrefs?: string[];
  href: string;
  isActive: boolean;
};

const allPages = import.meta.glob("/src/pages/**/*.{md,mdx,astro}", { eager: true });
const currentPath = Astro.url.pathname.replace(/\/+$/u, "") || "/";

const toHref = (filePath: string) => {
  const withoutSrcPages = filePath.replace(/^\/src\/pages/, "");
  const withoutExt = withoutSrcPages.replace(/\.(md|mdx|astro)$/i, "");
  const routePath = withoutExt.replace(/\/index$/i, "");
  return routePath === "" ? "/" : routePath;
};

const toSectionRootHref = (pagesDir: string) => {
  const routePath = pagesDir.replace(/^\/src\/pages/, "");
  return routePath === "" ? "/" : routePath;
};

const buildTopicsForDir = (pagesDir: string) =>
  Object.entries(allPages)
    .map(([filePath, mod]) => ({ filePath, mod: mod as PageModule }))
    .filter(({ filePath }) => filePath.startsWith(`${pagesDir}/`))
    .filter(({ filePath }) => !filePath.endsWith("/index.astro"))
    .map(({ filePath, mod }) => {
      const fileName = filePath.split("/").pop() ?? "";
      const slug = fileName.replace(/\.(md|mdx|astro)$/i, "");
      const navOrder = Number(mod.frontmatter?.navOrder ?? Number.POSITIVE_INFINITY);
      const navLabel = mod.frontmatter?.navLabel ?? toTitle(slug);
      return {
        label: navLabel,
        href: toHref(filePath),
        navOrder,
      };
    })
    .sort((a, b) => a.navOrder - b.navOrder || a.label.localeCompare(b.label, "es"));

const sections: SidebarSection[] = sidebarDomains
  .map((domain) => {
    const topics: SidebarTopic[] = buildTopicsForDir(domain.pagesDir);
    const sectionHref = domain.href ?? topics[0]?.href ?? "#";
    const sectionRootHref = toSectionRootHref(domain.pagesDir);
    const topicHrefs = topics.map((topic) => topic.href);
    const isActive =
      currentPath === sectionHref ||
      topicHrefs.some((href) => href === currentPath) ||
      (sectionRootHref !== "/" && currentPath.startsWith(`${sectionRootHref}/`)) ||
      (domain.pagesDir === "/src/pages/inicio" && currentPath.startsWith("/inicio/"));

    return {
      title: domain.title,
      icon: domain.icon,
      topics: topics.map((topic) => topic.label),
      topicHrefs,
      href: sectionHref,
      isActive,
    };
  })
  .filter((section) => section.topics.length > 0);
---

<aside>
  <div class="hidden xl:flex fixed left-0 top-16 z-40 flex-col p-md gap-xs bg-surface-container-lowest dark:bg-[#090a0d] border-r border-outline-variant dark:border-slate-800 w-sidebar_width h-[calc(100vh-64px)] overflow-y-auto">
    <nav class="flex flex-col gap-sm mb-md">
      {sections.map((section) => (
        <details class="group" open={section.isActive}>
          <summary class={`list-none cursor-pointer flex items-center justify-between gap-sm px-sm py-xs transition-all scale-95 active:scale-100 font-label-md text-label-md ${section.isActive ? "bg-secondary-container dark:bg-[#16284e] text-on-secondary-container dark:text-slate-100 rounded-full font-medium" : "text-on-surface-variant dark:text-slate-400 hover:bg-surface-container-low dark:hover:bg-[#131722] dark:hover:text-slate-100 rounded-lg"}`}>
            <span class="flex items-center gap-sm min-w-0 grow">
              <span class="material-symbols-outlined text-[20px]">{section.icon}</span>
              <span class="truncate">{section.title}</span>
            </span>
            <span class="material-symbols-outlined text-[18px] transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <ul class="mt-xs ml-xl pl-sm space-y-[2px] border-l border-outline-variant/60">
            {section.topics.map((topic, topicIdx) => (
              <li>
                <a
                  href={section.topicHrefs?.[topicIdx] ?? "#"}
                  class={`block py-[2px] font-label-sm text-label-sm leading-5 ${
                    section.topicHrefs?.[topicIdx] === currentPath
                      ? "text-primary dark:text-[#8ab0ff] font-medium"
                      : "text-on-surface-variant dark:text-slate-400 hover:text-primary dark:hover:text-slate-100"
                  }`}
                >
                  {topic}
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))}
    </nav>
  </div>

  <details class="xl:hidden fixed left-0 top-0 z-[70] mobile-sidebar" id="mobile-sidebar">
    <summary class="hidden"></summary>
    <button
      type="button"
      class="fixed inset-0 z-[70] bg-black/30 border-0 p-0 m-0 cursor-default"
      aria-label="Cerrar navegación"
      data-sidebar-backdrop
    ></button>
    <div class="fixed left-0 top-0 z-[80] w-[300px] h-screen bg-surface-container-lowest dark:bg-[#090a0d] border-r border-outline-variant dark:border-slate-800 p-md overflow-y-auto shadow-xl">
      {sections.map((section) => (
        <details class="group mb-sm" open={section.isActive}>
          <summary class={`list-none cursor-pointer flex items-center justify-between gap-sm px-sm py-xs transition-all scale-95 active:scale-100 font-label-md text-label-md ${section.isActive ? "bg-secondary-container dark:bg-[#16284e] text-on-secondary-container dark:text-slate-100 rounded-full font-medium" : "text-on-surface-variant dark:text-slate-400 hover:bg-surface-container-low dark:hover:bg-[#131722] dark:hover:text-slate-100 rounded-lg"}`}>
            <span class="flex items-center gap-sm min-w-0 grow">
              <span class="material-symbols-outlined text-[20px]">{section.icon}</span>
              <span class="truncate">{section.title}</span>
            </span>
            <span class="material-symbols-outlined text-[18px] transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <ul class="mt-xs ml-xl pl-sm space-y-[2px] border-l border-outline-variant/60">
            {section.topics.map((topic, topicIdx) => (
              <li>
                <a
                  href={section.topicHrefs?.[topicIdx] ?? "#"}
                  class={`block py-[2px] font-label-sm text-label-sm leading-5 ${
                    section.topicHrefs?.[topicIdx] === currentPath
                      ? "text-primary dark:text-[#8ab0ff] font-medium"
                      : "text-on-surface-variant dark:text-slate-400 hover:text-primary dark:hover:text-slate-100"
                  }`}
                >
                  {topic}
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))}
    </div>
  </details>
</aside>

<script is:inline>
  document.querySelectorAll(".mobile-sidebar").forEach((detailsEl) => {
    const backdrop = detailsEl.querySelector("[data-sidebar-backdrop]");
    if (!backdrop) return;
    backdrop.addEventListener("click", () => {
      detailsEl.removeAttribute("open");
    });
  });

  document.querySelectorAll("[data-open-sidebar]").forEach((openBtn) => {
    openBtn.addEventListener("click", () => {
      const sidebar = document.getElementById("mobile-sidebar");
      if (!sidebar) return;
      sidebar.setAttribute("open", "");
    });
  });
</script>
