---
const links = [
  "Política de privacidad",
  "Términos del servicio",
  "Seguridad",
  "Estado",
];
---

<footer class="bg-surface dark:bg-inverse-surface border-t border-outline-variant dark:border-outline full-width py-xl mt-xl">
  <div class="max-w-container_max_width mx-auto px-lg flex flex-col items-center gap-md">
    <div class="font-headline-md text-headline-md text-primary font-bold mb-sm">MyDevNotes</div>
    <div class="flex flex-wrap justify-center gap-md mb-sm">
      {links.map((link) => (
        <a
          href="#"
          class="text-on-surface-variant dark:text-outline-variant hover:text-primary dark:hover:text-inverse-primary underline transition-all opacity-90 hover:opacity-100 font-label-sm text-label-sm"
        >
          {link}
        </a>
      ))}
    </div>
    <div class="text-on-surface-variant dark:text-outline-variant font-label-sm text-label-sm">
      © 2026 MyDevNotes. Construido con precisión.
    </div>
  </div>
</footer>
