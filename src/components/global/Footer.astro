---
const links = [
  { label: "Home", href: "/" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/marcotinez/" },
  { label: "GitHub", href: "https://github.com/marcotinez" },
];
---

<footer class="bg-surface dark:bg-inverse-surface border-t border-outline-variant/40 dark:border-outline/40 py-md mt-md xl:pl-sidebar_width">
  <div class="max-w-container_max_width mx-auto px-lg flex flex-col items-center gap-sm">
    <div class="font-headline-md text-headline-md text-primary font-bold">MyDevNotes</div>
    <div class="flex flex-wrap justify-center gap-sm">
      {links.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith("http") ? "_blank" : undefined}
          rel={link.href.startsWith("http") ? "noreferrer noopener" : undefined}
          class="text-on-surface-variant dark:text-outline-variant hover:text-primary dark:hover:text-inverse-primary transition-colors font-label-sm text-label-sm"
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="text-on-surface-variant dark:text-outline-variant font-label-sm text-label-sm leading-none">
      © 2026 MyDevNotes. Construido con precisión.
    </div>
  </div>
</footer>
