---
const links = [
  { label: "Home", href: "/" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/marcotinez/" },
  { label: "GitHub", href: "https://github.com/marcotinez" },
];
---

<footer class="bg-surface dark:bg-inverse-surface border-t border-outline-variant dark:border-outline py-xl mt-xl">
  <div class="max-w-container_max_width mx-auto px-lg flex flex-col items-center gap-md">
    <div class="font-headline-md text-headline-md text-primary font-bold mb-sm">MyDevNotes</div>
    <div class="flex flex-wrap justify-center gap-md mb-sm">
      {links.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith("http") ? "_blank" : undefined}
          rel={link.href.startsWith("http") ? "noreferrer noopener" : undefined}
          class="text-on-surface-variant dark:text-outline-variant hover:text-primary dark:hover:text-inverse-primary transition-colors font-label-sm text-label-sm"
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="text-on-surface-variant dark:text-outline-variant font-label-sm text-label-sm">
      © 2026 MyDevNotes. Construido con precisión.
    </div>
  </div>
</footer>
