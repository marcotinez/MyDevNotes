---
import Footer from "../components/global/Footer.astro";
import Navbar from "../components/global/Navbar.astro";
import Sidebar from "../components/global/Sidebar.astro";
import HomeLayout from "./HomeLayout.astro";

interface Props {
  title: string;
  section: string;
  pageTitle: string;
  pageDescription?: string;
  prevPage?: { href: string; label: string };
  nextPage?: { href: string; label: string };
}

const { title, section, pageTitle, pageDescription, prevPage, nextPage } = Astro.props;
---

<HomeLayout title={title}>
  <div class="min-h-screen flex flex-col">
    <Navbar />
    <div class="flex-1 w-full xl:pl-sidebar_width">
      <Sidebar />
      <main class="w-full flex justify-center px-lg py-xl">
        <div class="max-w-content_max_width w-full min-h-[calc(100vh-64px-80px)] flex flex-col gap-xl">
          <nav class="flex items-center gap-sm font-label-sm text-label-sm text-outline sticky top-[64px] bg-surface z-40 py-sm">
            <a class="hover:text-primary transition-colors" href="/">MyDevNotes</a>
            <span>/</span>
            <a class="hover:text-primary transition-colors" href="/inicio/bienvenida">{section}</a>
            <span>/</span>
            <span class="text-on-surface">{pageTitle}</span>
          </nav>

          <header class="flex flex-col gap-md">
            <h1 class="font-headline-xl text-headline-xl text-on-background">{pageTitle}</h1>
            {pageDescription && (
              <p class="font-body-lg text-body-lg text-on-surface-variant">{pageDescription}</p>
            )}
          </header>

          <article
            class="prose prose-slate max-w-none flex-1 prose-headings:font-headline-lg prose-headings:text-on-background prose-p:font-body-md prose-p:text-on-surface prose-p:leading-relaxed prose-a:text-primary hover:prose-a:text-primary prose-strong:text-on-surface prose-ul:text-on-surface-variant prose-ol:text-on-surface-variant prose-li:marker:text-outline prose-code:font-code-block prose-code:text-primary prose-pre:rounded-xl prose-pre:border prose-pre:border-outline-variant prose-pre:bg-inverse-surface prose-pre:text-inverse-on-surface prose-blockquote:border-l-4 prose-blockquote:border-primary prose-blockquote:bg-surface-container-low prose-blockquote:text-on-surface-variant prose-blockquote:rounded-r-lg dark:prose-invert"
          >
            <slot />
          </article>

          {(prevPage || nextPage) && (
            <nav class="mt-auto pt-md border-t border-outline-variant/70">
              <div class="flex items-center justify-between gap-md">
              {prevPage ? (
                <a
                  href={prevPage.href}
                  class="inline-flex items-center gap-xs rounded-lg border border-primary/40 bg-surface-container-lowest px-md py-sm text-primary hover:bg-primary hover:text-on-primary transition-colors font-label-md text-label-md"
                >
                  <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                  <span>Anterior: {prevPage.label}</span>
                </a>
              ) : (
                <span />
              )}
              {nextPage ? (
                <a
                  href={nextPage.href}
                  class="inline-flex items-center gap-xs rounded-lg border border-primary bg-primary text-on-primary px-md py-sm hover:bg-primary-container hover:text-on-primary-container transition-colors font-label-md text-label-md"
                >
                  <span>Siguiente: {nextPage.label}</span>
                  <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </a>
              ) : (
                <span />
              )}
              </div>
            </nav>
          )}
        </div>
      </main>
    </div>
    <Footer />
  </div>
</HomeLayout>

<script is:inline>
  const enhanceCodeBlocks = () => {
    document.querySelectorAll("article pre").forEach((preEl) => {
      if (preEl.dataset.copyReady === "true") return;
      const codeEl = preEl.querySelector("code");
      if (!codeEl) return;

      preEl.dataset.copyReady = "true";
      preEl.classList.add("relative");

      const button = document.createElement("button");
      button.type = "button";
      button.textContent = "Copiar";
      button.className =
        "absolute top-2 right-2 rounded-md border border-outline-variant bg-surface/90 px-2 py-1 text-[11px] leading-none font-label-sm text-on-surface-variant hover:text-primary hover:border-primary transition-colors";

      button.addEventListener("click", async () => {
        const code = codeEl.textContent ?? "";
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code);
          button.textContent = "Copiado";
          button.classList.add("text-primary", "border-primary");
          window.setTimeout(() => {
            button.textContent = "Copiar";
            button.classList.remove("text-primary", "border-primary");
          }, 1400);
        } catch {
          button.textContent = "Error";
          window.setTimeout(() => {
            button.textContent = "Copiar";
          }, 1400);
        }
      });

      preEl.appendChild(button);
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", enhanceCodeBlocks);
  } else {
    enhanceCodeBlocks();
  }
</script>
